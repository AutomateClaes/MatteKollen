rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Parkoppling: barnenheten (anonymt inloggad) skapar ett dokument
    // med en sexsiffrig kod som ID. Föräldern som känner till koden
    // godkänner genom att stämpla sin familj på dokumentet.
    // list är avstängt — koden är hemligheten.
    match /linkRequests/{code} {
      allow create: if request.auth != null
        && request.resource.data.deviceUid == request.auth.uid
        && request.resource.data.status == 'pending';
      allow get: if request.auth != null;
      allow list: if false;
      allow update: if request.auth != null
        && request.resource.data.familyUid == request.auth.uid
        && request.resource.data.deviceUid == resource.data.deviceUid;
      allow delete: if request.auth != null
        && (request.auth.uid == resource.data.deviceUid
            || request.auth.uid == resource.data.familyUid);
    }

    match /families/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;

      // Godkända enhetskopplingar: deviceUid -> profileId
      match /grants/{deviceUid} {
        allow read: if request.auth != null
          && (request.auth.uid == uid || request.auth.uid == deviceUid);
        allow write: if request.auth != null && request.auth.uid == uid;
      }

      match /profiles/{profileId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;

        // Profilens framsteg: föräldern, eller en enhet med godkänd
        // koppling till just denna profil
        match /state/{stateDoc} {
          allow read, write: if request.auth != null
            && (request.auth.uid == uid
                || get(/databases/$(database)/documents/families/$(uid)/grants/$(request.auth.uid)).data.profileId == profileId);
        }
      }
    }
  }
}
